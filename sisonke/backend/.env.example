# Server Configuration
PORT=3001
NODE_ENV=development

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Authentication
JWT_SECRET=your_jwt_secret_change_me_in_production
JWT_EXPIRES_IN=7d

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
FRONTEND_URL=http://localhost:3000

# Local AI for development only.
# Install Ollama, then run: ollama pull qwen2.5:1.5b
LOCAL_AI_ENABLED=false
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=qwen2.5:1.5b
OLLAMA_TIMEOUT_MS=12000

# Optional Gemini fallback for complex dev/test questions.
# Keep the real key only in backend/.env or production secrets.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_MS=15000
