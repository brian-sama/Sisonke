# Sisonke Production Environment Variables
# COPY THIS FILE TO THE VPS AS .env.production AND FILL IN THE SECRETS

NODE_ENV=production
PORT=3001

# Neon/PostgreSQL Connection String
# Get this from your Neon Dashboard
DATABASE_URL=postgres://user:password@host.neon.tech/dbname?sslmode=require

# JWT Secrets (Generate long random strings)
JWT_SECRET=replace_with_a_secure_long_random_string
JWT_REFRESH_SECRET=replace_with_another_secure_long_random_string

# Allowed CORS Origins (Your mobile/web domains)
ALLOWED_ORIGINS=https://sisonke.co.zw,https://admin.sisonke.co.zw,http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# AI Toggles (Set to true if Ollama is running on the VPS)
LOCAL_AI_ENABLED=false
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Gemini Fallback (Optional but recommended)
GEMINI_API_KEY=your_gemini_api_key_here
