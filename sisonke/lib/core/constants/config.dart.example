/// Example configuration file.
/// Copy this to lib/app/core/constants/config.dart and fill in your actual values.
/// DO NOT COMMIT config.dart to version control!

class Config {
  // Neon Postgres connection string
  // Get this from your Neon dashboard: https://console.neon.tech
  // Format: postgresql://username:password@host/database?sslmode=require
  static const String neonConnectionString = 'YOUR_NEON_CONNECTION_STRING_HERE';

  // Cloudinary configuration (optional, for image storage)
  // Get this from your Cloudinary dashboard: https://cloudinary.com
  static const String cloudinaryCloudName = 'YOUR_CLOUDINARY_CLOUD_NAME_HERE';
  static const String cloudinaryApiKey = 'YOUR_CLOUDINARY_API_KEY_HERE';
  
  // Vercel configuration (optional, for edge functions)
  // Get this from your Vercel project dashboard
  static const String vercelBaseUrl = 'https://your-project.vercel.app/api';
}
