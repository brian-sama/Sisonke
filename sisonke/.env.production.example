POSTGRES_DB=sisonke
POSTGRES_USER=sisonke
POSTGRES_PASSWORD=replace-with-a-long-random-database-password
JWT_SECRET=replace-with-at-least-32-random-characters-for-jwt-signing
JWT_EXPIRES_IN=7d
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300

# Used only when running: docker compose -f docker-compose.prod.yml run --rm backend npm run admin:create
ADMIN_EMAIL=admin@sisonke.mmpzmne.co.zw
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# AI runtime for the Sisonke Friend graph.
# In Docker Compose, Ollama is reachable by service name, not localhost.
LOCAL_AI_ENABLED=true
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=qwen2.5:1.5b
OLLAMA_HEALTH_TIMEOUT_MS=1500
OLLAMA_TIMEOUT_MS=12000

# Optional cloud fallback. Keep disabled unless you have reviewed privacy/cost.
EXTERNAL_AI_FALLBACK_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_MS=15000
RAG_DB_TIMEOUT_MS=1500

# Host Nginx proxies to these localhost-only Docker ports.
BACKEND_HOST_PORT=3001
ADMIN_HOST_PORT=3016
