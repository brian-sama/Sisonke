# Environment Variables Example
# Copy this to .env and fill in your actual values
# DO NOT COMMIT .env to version control!

# Neon Database
NEON_CONNECTION_STRING=postgresql://username:password@host/database?sslmode=require

# Firebase
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_STORAGE_BUCKET=your_storage_bucket.appspot.com

# Cloudinary (for image storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key

# Vercel (for edge functions)
VERCEL_BASE_URL=https://your-project.vercel.app/api

# App Settings
APP_ENV=development
LOG_LEVEL=debug